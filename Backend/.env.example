# Porta del server Express
PORT=3000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<AppName>

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SendGrid (https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=
SENDER_EMAIL=

# JWT — stringa casuale lunga almeno 32 caratteri
JWT_SECRET=

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# URL del frontend (usato per CORS e redirect OAuth)
FRONTEND_URL=http://localhost:3001

# Minuti di validità del link email per conferma cambio password
PASSWORD_CHANGE_TOKEN_TTL_MINUTES=30
